## Section 5 — thread-per-device concurrency probe (sharding go/no-go)

```
$ /usr/local/bin/python -c 
import sys, threading, time
sys.path.insert(0, '.')
import numpy as np
from gpu_speed import make_data
from masamlp import MasaRegressor

X, y = make_data(30_000, pred_rows=0)[:2]
KW = dict(model='resnet', n_epochs=20, amp=False, verbose=0,
          model_params={'d': 256, 'n_blocks': 2})

def fit_on(dev, seed, out, i):
    # NOTE: concurrent fits race on process-global seeding here; fine for a
    # feasibility probe (the real sharding path would use seed_scope='device').
    try:
        m = MasaRegressor(device=dev, random_state=seed, **KW)
        t0 = time.time(); m.fit(X, y); out[i] = (time.time() - t0, None)
    except Exception as e:
        out[i] = (None, f'{type(e).__name__}: {str(e)[:200]}')

seq = [None, None]
t0 = time.time()
for i in range(2):
    fit_on('xla:0', i, seq, i)
seq_wall = time.time() - t0
print(f'sequential on xla:0: {seq}, wall {seq_wall:.1f}s', flush=True)

conc = [None, None, None, None]
t0 = time.time()
threads = [threading.Thread(target=fit_on, args=(f'xla:{i}', i, conc, i))
           for i in range(4)]
[t.start() for t in threads]; [t.join() for t in threads]
conc_wall = time.time() - t0
print(f'concurrent on xla:0-3: {conc}, wall {conc_wall:.1f}s', flush=True)
errs = [c[1] for c in conc if c and c[1]]
per_fit_seq = seq_wall / 2
ideal = per_fit_seq  # 4 fits in parallel should take ~1 fit's time
print(f'VERDICT: {"THREAD-SHARDING FEASIBLE" if not errs and conc_wall < 2.5 * per_fit_seq else "NOT CONFIRMED"} '
      f'(4 concurrent fits wall {conc_wall:.1f}s vs single-fit {per_fit_seq:.1f}s)', flush=True)

